NODE_ENV=production
PORT=8080

# Database (Cloud SQL via Unix socket in production)
DATABASE_URL=postgresql://voiceai_user:YOUR_DB_PASSWORD@/voiceai?host=/cloudsql/sterling-ai-workshop:europe-west1:voiceai-db

# Redis
REDIS_URL=redis://34.180.63.117:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_here

# CORS
FRONTEND_URL=https://app.sterlingaiacademy.com

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# LiveKit
LIVEKIT_URL=wss://your-livekit-host.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_WEBHOOK_SECRET=your_livekit_webhook_secret

# GCP
GCP_PROJECT_ID=sterling-ai-workshop
GCS_BUCKET=voiceai-recordings

# Pub/Sub topics
PUBSUB_TOPIC_CALLS=voiceai-call-events
PUBSUB_TOPIC_BILLING=voiceai-billing

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# SMTP (for emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=VoiceAI <noreply@sterlingaiacademy.com>

# Internal agent secret (shared with Python agent)
INTERNAL_API_SECRET=your_strong_random_internal_secret
